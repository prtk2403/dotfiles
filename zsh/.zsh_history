: 1680543590:0;java VC
: 1680543821:0;javac VC.java
: 1680543849:0;import java.util.ArrayList;\
import java.util.List;\
\
public class VC {\
    static final int V = 8;\
    static List<Integer> vc = new ArrayList<>();\
\
    static void findVertexCover(int graph[][]) {\
        boolean visited[] = new boolean[V];\
        for (int i = 0; i < V; i++)\
            visited[i] = false;\
\
        for (int u = 0; u < V; u++) {\
            if (!visited[u]) {\
                for (int v = 0; v < V; v++) {\
                    if (graph[u][v] == 1 && !visited[v]) {\
                        visited[v] = true;\
                        visited[u] = true;\
                        System.out.println("Edge (" + u + ", " + v + ") is part of the vertex cover");\
                        break;\
                    }\
                }\
            }\
        }\
\
        for (int j = 0; j < V; j++)\
            if (visited[j])\
                vc.add(j);\
    }\
\
    public static void main(String[] args) {\
        int[][] graph = new int[V][V];\
        String mobileNumber = "9848140627";\
        for (int i = 0; i < V; i++) {\
            for (int j = i + 1; j < V; j++) {\
                if (Character.getNumericValue(mobileNumber.charAt(i)) >= 5\
                        && Character.getNumericValue(mobileNumber.charAt(j)) >= 5) {\
                    graph[i][j] = 1;\
                    graph[j][i] = 1;\
                }\
            }\
        }\
\
        findVertexCover(graph);\
\
        System.out.println("Vertex Cover: ");\
        for (int i : vc)\
            System.out.print(i + " ");\
    }\
}
